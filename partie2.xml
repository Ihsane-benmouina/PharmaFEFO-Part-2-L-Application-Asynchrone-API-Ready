// public/js/dashboard.js

document.addEventListener("DOMContentLoaded", () => {
    
    // Initialisation
    loadDashboardAlerts();
    initFilterControls();
    initActionButtons();
    initAsyncFormSubmit();

    // TÂCHE 5 : Compteur d'Alerte Automatique
    function loadDashboardAlerts() {
        fetch('index.php?action=api/v1/dashboard/alerts')
            .then(res => window.PharmaUI.handleHttpError(res))
            .then(res => {
                if (res.success && res.data.expiringNextMonth > 0) {
                    const banner = document.getElementById('async-alert-banner');
                    const textSpan = document.getElementById('async-alert-text');
                    if (banner && textSpan) {
                        textSpan.innerText = `⚠️ Prévoyance FEFO : ${res.data.expiringNextMonth} produits expirent le mois prochain.`;
                        banner.classList.remove('hidden');
                    }
                }
            })
            .catch(err => console.error("Erreur d'alerte : ", err));
    }

    // TÂCHE 4 : Filtres Dynamiques
    function initFilterControls() {
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const criteria = e.currentTarget.getAttribute('data-criteria');
                
                fetch(`index.php?action=api/v1/batches&criteria=${criteria}`)
                    .then(res => window.PharmaUI.handleHttpError(res))
                    .then(res => {
                        if (res.success) {
                            renderTable(res.data);
                            window.PharmaUI.showToast("Données du stock actualisées.");
                        }
                    })
                    .catch(err => console.error(err));
            });
        });
    }

    function renderTable(batches) {
        const tbody = document.getElementById('batch-table-body');
        if (!tbody) return;

        tbody.innerHTML = '';
        if (batches.length === 0) {
            tbody.innerHTML = `<tr><td colspan="7" class="p-6 text-center text-gray-400 font-medium">Aucun lot de stock trouvé.</td></tr>`;
            return;
        }

        batches.forEach(l => {
            const tr = document.createElement('tr');
            tr.className = 'border-b border-slate-200';
            tr.setAttribute('data-id', l.id);
            tr.setAttribute('data-product-id', l.productId);

            tr.innerHTML = `
                <td class="p-3 font-semibold text-gray-900">${l.productName || 'Médicament'}</td>
                <td class="p-3 font-mono text-gray-500">${l.id}</td>
                <td class="p-3 font-bold text-gray-700">${l.batchNumber}</td>
                <td class="p-3 batch-qty">${l.quantity}</td>
                <td class="p-3">${l.expiryDate}</td>
                <td class="p-3">
                    <span class="px-2.5 py-1 rounded-full text-[11px] font-medium border ${l.color_classes}">
                        ${l.badge_text}
                    </span>
                </td>
                <td class="p-3 text-right space-x-1">
                    <button class="btn-checkout bg-emerald-600 hover:bg-emerald-700 text-white text-[10px] uppercase font-bold px-2 py-1 rounded">Délivrer 1 boîte</button>
                    <button class="btn-expire bg-rose-600 hover:bg-rose-700 text-white text-[10px] uppercase font-bold px-2 py-1 rounded">Périmer</button>
                </td>
            `;
            tbody.appendChild(tr);
        });

        // Ré-attacher les écouteurs sur les éléments nouvellement créés dans le DOM
        initActionButtons();
    }

    // TÂCHES 6 et 7 : Sortie FEFO & Péremption en cascade
    function initActionButtons() {
        const tbody = document.getElementById('batch-table-body');
        if (!tbody) return;

        tbody.removeAttribute('data-has-listeners'); // Clear signature

        tbody.onclick = function(event) {
            const target = event.target;

            // Sortie Asynchrone (Tâche 6)
            if (target.classList.contains('btn-checkout')) {
                const tr = target.closest('tr');
                const productId = tr.getAttribute('data-product-id');
                
                const formData = new FormData();
                formData.append('produit_id', productId);
                formData.append('quantite', 1);

                fetch('index.php?action=api/v1/batches/checkout', {
                    method: 'POST',
                    body: formData
                })
                .then(res => window.PharmaUI.handleHttpError(res))
                .then(res => {
                    if (res.success) {
                        window.PharmaUI.showToast("Déstockage validé via algorithme FEFO.");
                        // Rafraîchir l'affichage par appel du filtre courant automatique
                        document.querySelector('.filter-btn[data-criteria="all"]').click();
                    }
                })
                .catch(err => {
                    if (typeof err.json === 'function') {
                        err.json().then(json => window.PharmaUI.showToast(json.message, "error"));
                    }
                });
            }

            // Marquage Périmé Direct (Tâche 7)
            if (target.classList.contains('btn-expire')) {
                const tr = target.closest('tr');
                const batchId = tr.getAttribute('data-id');

                if (!confirm("Voulez-vous immédiatement forcer la péremption de ce lot ?")) return;

                fetch(`index.php?action=api/v1/batches/${batchId}/expire`, {
                    method: 'PATCH'
                })
                .then(res => window.PharmaUI.handleHttpError(res))
                .then(res => {
                    if (res.success) {
                        window.PharmaUI.showToast(res.message);
                        // Modification immédiate du DOM local avant rafraîchissement global
                        const qtyTd = tr.querySelector('.batch-qty');
                        if (qtyTd) qtyTd.innerText = '0';
                        tr.style.opacity = '0.5';
                        tr.style.background = '#f8fafc';
                        target.remove(); // Retrait du bouton
                    }
                })
                .catch(err => {
                    if (typeof err.json === 'function') {
                        err.json().then(json => window.PharmaUI.showToast(json.message, "error"));
                    }
                });
            }
        };
    }

    // TÂCHE 3 : Formulaire d'Ajout Asynchrone (add_batch.php)
    function initAsyncFormSubmit() {
        const form = document.querySelector('form[action="index.php?action=add-batch"]');
        if (!form) return;

        form.addEventListener('submit', (e) => {
            e.preventDefault();

            const formData = new FormData(form);

            fetch('index.php?action=api/v1/batches', {
                method: 'POST',
                body: formData
            })
            .then(res => window.PharmaUI.handleHttpError(res))
            .then(res => {
                if (res.success) {
                    window.PharmaUI.showToast(res.message, "success");
                    form.reset(); // Vider le formulaire d'entrée
                }
            })
            .catch(err => {
                if (typeof err.json === 'function') {
                    err.json().then(json => window.PharmaUI.showToast(json.message, "error"));
                } else {
                    console.error(err);
                }
            });
        });
    }
});
