<?php
// public/index.php

// 1. CHARGEMENT DE LA CONFIGURATION ET DE L'ENVIRONNEMENT
require_once __DIR__ . '/../config/environment.php';
require_once __DIR__ . '/../src/Service/AuthService.php';

// Initialisation globale de la session pour toutes les requêtes (Web et API)
AuthService::initSession();

// Récupération de l'action demandée
$action = $_GET['action'] ?? 'dashboard';

// 2. ROUTAGE DES REQUÊTES API REST (Asynchrone - Réponses JSON)
if (strpos($action, 'api/v1/') === 0 || (isset($_SERVER['PATH_INFO']) && strpos($_SERVER['PATH_INFO'], '/api/') === 0)) {
    
    // Normalisation élémentaire de la route demandée
    $route = isset($_GET['action']) ? $_GET['action'] : trim($_SERVER['PATH_INFO'], '/');
    $method = $_SERVER['REQUEST_METHOD'];

    // Routes pour les lots (Stock)
    if ($route === 'api/v1/batches') {
        require_once __DIR__ . '/../src/Controller/Api/ApiStockController.php';
        $controller = new ApiStockController();
        if ($method === 'GET') {
            $controller->listBatches();
        } elseif ($method === 'POST') {
            $controller->createBatch();
        }
        exit;
    }
    
    // Route pour les alertes du tableau de bord
    if ($route === 'api/v1/dashboard/alerts' && $method === 'GET') {
        require_once __DIR__ . '/../src/Controller/Api/ApiDashboardController.php';
        $controller = new ApiDashboardController();
        $controller->getAlerts();
        exit;
    }

    // Route pour le déstockage FEFO
    if ($route === 'api/v1/batches/checkout' && $method === 'POST') {
        require_once __DIR__ . '/../src/Controller/Api/ApiStockController.php';
        $controller = new ApiStockController();
        $controller->checkout();
        exit;
    }

    // Route dynamique pour forcer la péremption : api/v1/batches/{id}/expire
    if (preg_match('/^api\/v1\/batches\/(\d+)\/expire$/', $route, $matches) && $method === 'PATCH') {
        require_once __DIR__ . '/../src/Controller/Api/ApiStockController.php';
        $controller = new ApiStockController();
        $controller->markExpired((int)$matches[1]);
        exit;
    }

    // Si aucun endpoint d'API ne correspond
    header('Content-Type: application/json');
    http_response_code(404);
    echo json_encode(["success" => false, "message" => "Endpoint API introuvable."]);
    exit;
}

// 3. ROUTAGE DES REQUÊTES WEB (Rendu des vues HTML/PHP)

// Sécurité : Empêcher l'accès anonyme sur tout le périmètre Web sauf la page de login
if (!AuthService::isAuthenticated() && $action !== 'login') {
    header("Location: index.php?action=login");
    exit;
}

switch ($action) {
    case 'login':
        require_once __DIR__ . '/../src/Controller/Web/AuthController.php';
        (new AuthController())->login();
        break;

    case 'logout':
        require_once __DIR__ . '/../src/Controller/Web/AuthController.php';
        (new AuthController())->logout();
        break;

    case 'dashboard':
        // CORRIGÉ : Pointage vers le sous-dossier Web/
        require_once __DIR__ . '/../src/Controller/Web/DashboardController.php';
        (new DashboardController())->index();
        break;

    case 'users':
        // CORRIGÉ : Pointage vers le sous-dossier Web/
        require_once __DIR__ . '/../src/Controller/Web/DashboardController.php';
        (new DashboardController())->manageUsers();
        break;

    case 'add-batch':
        // CORRIGÉ : Pointage vers le sous-dossier Web/
        require_once __DIR__ . '/../src/Controller/Web/StockController.php';
        (new StockController())->addBatch();
        break;

    case 'dispense':
        // CORRIGÉ : Pointage vers le sous-dossier Web/
        require_once __DIR__ . '/../src/Controller/Web/StockController.php';
        (new StockController())->dispense();
        break;

    case 'admin/reports':
        require_once __DIR__ . '/../src/Controller/Web/AdminController.php';
        (new AdminController())->reports();
        break;

    default:
        http_response_code(404);
        echo "<div style='padding: 20px; font-family: sans-serif;'><strong>Erreur 404 :</strong> Page Web introuvable.</div>";
        break;
}
