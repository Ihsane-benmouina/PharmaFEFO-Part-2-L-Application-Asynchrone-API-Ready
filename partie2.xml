// Définition de l'environnement : 'development' ou 'production'
define('APP_ENV', 'development'); // Rj3ha 'development' bache t-biyyen l-errors
if (APP_ENV === 'development') {
    error_reporting(E_ALL);
    ini_set('display_errors', '1');
    ini_set('display_startup_errors', '1');
} else {
    error_reporting(0);
    ini_set('display_errors', '0');
    ini_set('display_startup_errors', '0');
    
    // Gestionnaire global d'exceptions pour la production
    set_exception_handler(function ($exception) {
        $isApi = (strpos($_SERVER['REQUEST_URI'], '/api/') !== false);
        
        if ($isApi) {
            header('Content-Type: application/json');
            http_response_code(500);
            echo json_encode([
                "success" => false,
                "message" => "Une erreur interne au serveur est survenue (HTTP 500)."
            ]);
        } else {
            http_response_code(500);
            include __DIR__ . '/../templates/errors/500.php'; // Ou affichage générique alternatif
        }
        exit;
    });
}
