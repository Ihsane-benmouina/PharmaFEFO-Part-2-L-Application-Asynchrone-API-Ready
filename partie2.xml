// FIX: Si PharmaUI existe déjà, on ne le redéclare pas avec const
window.PharmaUI = window.PharmaUI || {
    
    // Centralisation de la gestion des erreurs HTTP (Tâche 2)
    handleHttpError: function(response) {
        if (!response.ok) {
            const error = new Error(response.statusText);
            error.response = response;
            throw error;
        }
        // Si la réponse est du JSON, on la retourne, sinon on gère le texte
        const contentType = response.headers.get("content-type");
        if (contentType && contentType.indexOf("application/json") !== -1) {
            return response.json();
        }
        return response.text();
    },

    // Composant global pour afficher les Toasts/Alertes de manière asynchrone
    showToast: function(message, type = 'success') {
        // Recherche ou création du container de toasts
        let container = document.getElementById('pharma-toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'pharma-toast-container';
            container.className = 'fixed bottom-5 right-5 z-50 space-y-2';
            document.body.appendChild(container);
        }

        const toast = document.createElement('div');
        const bgClass = type === 'error' ? 'bg-rose-600' : (type === 'warning' ? 'bg-amber-500' : 'bg-emerald-600');
        
        toast.className = `${bgClass} text-white px-4 py-3 rounded-lg shadow-lg text-xs font-bold transition-all duration-300 transform translate-y-2 opacity-0 flex items-center gap-2`;
        toast.innerHTML = `<span>${type === 'error' ? '❌' : '✨'}</span> <span>${message}</span>`;
        
        container.appendChild(toast);

        // Animation d'apparition
        setTimeout(() => {
            toast.classList.remove('translate-y-2', 'opacity-0');
        }, 10);

        // Disparition automatique après 4 secondes
        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-y-2');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }
};
class PharmaUI {
    /**
     * Crée et affiche une notification contextuelle épurée (Toast CSS) dans le coin supérieur droit.
     * Interdiction d'utiliser alert().
     */

    
    static showToast(message, type = 'success') {
        let container = document.getElementById('toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.style.position = 'fixed';
            container.style.top = '20px';
            container.style.right = '20px';
            container.style.zIndex = '9999';
            container.style.display = 'flex';
            container.style.flexDirection = 'column';
            container.style.gap = '10px';
            document.body.appendChild(container);
        }

        const toast = document.createElement('div');
        toast.style.padding = '14px 20px';
        toast.style.borderRadius = '8px';
        toast.style.fontSize = '12px';
        toast.style.fontWeight = '700';
        toast.style.fontFamily = 'sans-serif';
        toast.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
        toast.style.minWidth = '280px';
        toast.style.transition = 'all 0.3s ease';
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(-20px)';

        if (type === 'success') {
            toast.style.background = '#ecfdf5';
            toast.style.color = '#065f46';
            toast.style.borderLeft = '5px solid #10b981';
        } else {
            toast.style.background = '#fef2f2';
            toast.style.color = '#991b1b';
            toast.style.borderLeft = '5px solid #ef4444';
        }

        toast.innerText = message;
        container.appendChild(toast);

        // Effet d'apparition
        setTimeout(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
        }, 50);

        // Effet de disparition automatique après 4 secondes
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }

    /**
     * Centralisation de la capture d'erreur HTTP globale pour l'API Fetch
     */
    static handleHttpError(response) {
        if (response.status === 403) {
            PharmaUI.showToast("Erreur 403 : Droits d'accès insuffisants (Action Refusée).", "error");
            throw new Error("403 Forbidden");
        }
        if (response.status === 404) {
            PharmaUI.showToast("Erreur 404 : La ressource demandée n'existe pas.", "error");
            throw new Error("404 Not Found");
        }
        if (response.status === 422) {
            throw response; // Traité localement pour afficher les messages métier détaillés
        }
        if (response.status >= 500) {
            PharmaUI.showToast("Erreur 500 : Problème technique sur le serveur critique.", "error");
            throw new Error("500 Internal Server Error");
        }
        if (!response.ok) {
            PharmaUI.showToast("Erreur réseau inattendue.", "error");
            throw new Error("HTTP Error");
        }
        return response.json();
    }
}

// Rendre global
window.PharmaUI = PharmaUI;
